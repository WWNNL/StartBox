<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:StartBox.Controls"
             mc:Ignorable="d"  d:DesignWidth="400" d:DesignHeight="300"
             x:Class="StartBox.Controls.SelectCard" Background="{DynamicResource TempBackgroundGradient}">
    <UserControl.Styles>
        <Style Selector="TextBlock.icon-only">
            <Setter Property="FontSize" Value="128"></Setter>
            <Setter Property="HorizontalAlignment" Value="Center"></Setter>
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
            <Setter Property="FontFamily" Value="{DynamicResource Phosphor}"></Setter>
        </Style>
    </UserControl.Styles>
    <Border Padding="8" BorderThickness="1" CornerRadius="8" Classes="acrylic"
            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" Width="200" Height="200">
        <Grid RowDefinitions="2.6* *">
            <TextBlock Text="{Binding $parent[local:SelectCard].Icon}" Classes="icon-only"/>
            <TextBlock Grid.Row="1" Text="{Binding $parent[local:SelectCard].Text}" HorizontalAlignment="Center"></TextBlock>
        </Grid>
    </Border>
</UserControl>

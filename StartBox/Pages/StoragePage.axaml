<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="618" d:DesignHeight="618"
             xmlns:controls="using:StartBox.Controls"
             Background="{DynamicResource TempBackgroundGradient}"
             x:Class="StartBox.Pages.StoragePage">
    <ScrollViewer>
        <WrapPanel Name="PanelGridContainer" Orientation="Horizontal" HorizontalAlignment="Left">
            <controls:GridCard></controls:GridCard>
            <controls:GridCard></controls:GridCard>
            <controls:GridCard></controls:GridCard>
            <controls:GridCard></controls:GridCard>
            <controls:GridCard></controls:GridCard>
            <controls:GridCard></controls:GridCard>
            <controls:GridCard></controls:GridCard>
            <controls:GridCard></controls:GridCard>
        </WrapPanel>
    </ScrollViewer>
</UserControl>

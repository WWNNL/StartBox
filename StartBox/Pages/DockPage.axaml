<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="382" d:DesignHeight="618"
             xmlns:controls="using:StartBox.Controls"
             Background="{DynamicResource TempBackgroundGradient}"
             x:Class="StartBox.Pages.DockPage">
    <ScrollViewer>
        <StackPanel x:Name="NavList">
            <controls:DockButton Icon="&#xE560;" Text="桌面"></controls:DockButton>
            <controls:DockButton Icon="&#xE390;" Text="收纳盒"></controls:DockButton>
        </StackPanel>
    </ScrollViewer>
</UserControl>

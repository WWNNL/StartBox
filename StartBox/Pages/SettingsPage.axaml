<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="618" d:DesignHeight="618"
             xmlns:controls="using:StartBox.Controls"
             Background="{DynamicResource PrimaryBackgroundGradient}"
             x:Class="StartBox.Pages.SettingsPage">
    <UserControl.Styles>
        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="44"></Setter>
        </Style>
    </UserControl.Styles>
    <StackPanel>
        <TextBlock Text="设置" Classes="title"/>
        <Polyline Height="20" Width="20"></Polyline>
    </StackPanel>
</UserControl>
